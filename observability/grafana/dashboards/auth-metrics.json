{
  "uid": "auth-metrics",
  "title": "Authentication Metrics",
  "description": "Login success/failure rate and token generation latency for the auth service",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Login Success Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "rate(zenandops_auth_login_attempts_total{outcome=\"success\"}[5m])",
          "legendFormat": "Success"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "id": 2,
      "title": "Login Failure Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "rate(zenandops_auth_login_attempts_total{outcome=\"failure\"}[5m])",
          "legendFormat": "Failure"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "id": 3,
      "title": "Login Success/Failure Ratio",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "sum(rate(zenandops_auth_login_attempts_total{outcome=\"success\"}[5m])) / sum(rate(zenandops_auth_login_attempts_total[5m]))",
          "legendFormat": "Success Ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Token Generation Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"zenandops-auth\", uri=~\"/api/v1/auth/(login|refresh)\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"zenandops-auth\", uri=~\"/api/v1/auth/(login|refresh)\"}[5m])) by (le)) * 1000",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true
          }
        }
      }
    }
  ],
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s"
}
