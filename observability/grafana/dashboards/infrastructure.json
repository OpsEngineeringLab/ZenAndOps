{
  "uid": "infrastructure",
  "title": "Infrastructure (OTel Collector & Kafka)",
  "description": "OpenTelemetry Collector pipeline metrics and Kafka producer metrics",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "OTel Collector — Exported Spans (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "sum(rate(otelcol_exporter_sent_spans_total[5m])) by (exporter)",
          "legendFormat": "{{exporter}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "title": "OTel Collector — Exported Metric Points (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "sum(rate(otelcol_exporter_sent_metric_points_total[5m])) by (exporter)",
          "legendFormat": "{{exporter}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 3,
      "title": "OTel Collector — Exported Log Records (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "sum(rate(otelcol_exporter_sent_log_records_total[5m])) by (exporter)",
          "legendFormat": "{{exporter}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 4,
      "title": "OTel Collector — Failed Exports (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "sum(rate(otelcol_exporter_send_failed_spans_total[5m])) by (exporter)",
          "legendFormat": "spans — {{exporter}}"
        },
        {
          "expr": "sum(rate(otelcol_exporter_send_failed_metric_points_total[5m])) by (exporter)",
          "legendFormat": "metrics — {{exporter}}"
        },
        {
          "expr": "sum(rate(otelcol_exporter_send_failed_log_records_total[5m])) by (exporter)",
          "legendFormat": "logs — {{exporter}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 5,
      "title": "OTel Collector — Receiver Accepted (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "sum(rate(otelcol_receiver_accepted_spans_total[5m])) by (receiver)",
          "legendFormat": "spans — {{receiver}}"
        },
        {
          "expr": "sum(rate(otelcol_receiver_accepted_metric_points_total[5m])) by (receiver)",
          "legendFormat": "metrics — {{receiver}}"
        },
        {
          "expr": "sum(rate(otelcol_receiver_accepted_log_records_total[5m])) by (receiver)",
          "legendFormat": "logs — {{receiver}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 6,
      "title": "OTel Collector — Queue Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "otelcol_exporter_queue_size",
          "legendFormat": "{{exporter}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 7,
      "title": "Kafka Producer — Record Send Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "sum(rate(kafka_producer_record_send_total[5m])) by (job)",
          "legendFormat": "{{job}} records/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 8,
      "title": "Kafka Producer — Request Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(kafka_producer_request_latency_seconds_bucket[5m])) by (le, job)) * 1000",
          "legendFormat": "p95 — {{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    }
  ],
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s"
}
