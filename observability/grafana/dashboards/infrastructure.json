{
  "uid": "infrastructure",
  "title": "Infrastructure (MongoDB & Kafka)",
  "description": "Container resource metrics for MongoDB and Kafka",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "custom",
        "label": "Container",
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "zenandops-mongodb", "value": "zenandops-mongodb", "selected": false },
          { "text": "zenandops-kafka", "value": "zenandops-kafka", "selected": false }
        ],
        "query": "zenandops-mongodb,zenandops-kafka",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "container_cpu_utilization_ratio{job=~\"$container\"} * 100",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "container_memory_usage_total_bytes{job=~\"$container\"}",
          "legendFormat": "{{job}} used"
        },
        {
          "expr": "container_memory_usage_limit_bytes{job=~\"$container\"}",
          "legendFormat": "{{job}} limit"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 3,
      "title": "Memory Usage (%)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "container_memory_percent_ratio{job=~\"$container\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Network I/O (bytes/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "rate(container_network_io_usage_rx_bytes_total{job=~\"$container\"}[5m])",
          "legendFormat": "{{job}} rx"
        },
        {
          "expr": "rate(container_network_io_usage_tx_bytes_total{job=~\"$container\"}[5m])",
          "legendFormat": "{{job}} tx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 5,
      "title": "Block I/O (bytes/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "rate(container_blockio_io_service_bytes_recursive_total{job=~\"$container\"}[5m])",
          "legendFormat": "{{job}} {{operation}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 6,
      "title": "Kafka Producer — Record Send Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "kafka_producer_record_send_rate",
          "legendFormat": "{{job}} records/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 7,
      "title": "Kafka Producer — Request Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "kafka_producer_request_latency_avg",
          "legendFormat": "avg"
        },
        {
          "expr": "kafka_producer_request_latency_max",
          "legendFormat": "max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 8,
      "title": "Kafka Producer — Error & Retry Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "targets": [
        {
          "expr": "kafka_producer_record_error_rate",
          "legendFormat": "error rate"
        },
        {
          "expr": "kafka_producer_record_retry_rate",
          "legendFormat": "retry rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    }
  ],
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s"
}
