# Gateway Service base URL (used by ApiClient for all API requests)
# Leave EMPTY for local development with Vite dev server (npm run dev) — the
# Vite proxy in vite.config.ts handles forwarding /api requests to the gateway.
# Only set a value for production builds (e.g., Docker).
VITE_GATEWAY_URL=

# Keycloak OIDC configuration
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=zenandops
VITE_KEYCLOAK_CLIENT_ID=zenandops-frontend
