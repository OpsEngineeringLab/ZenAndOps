# =============================================================================
# ZenAndOps - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All variables are required — docker-compose.yml has no defaults.
# =============================================================================

# --- Project Version ---
# Must match the version in pom.xml / package.json
ZENANDOPS_VERSION=1.7.0

# --- MongoDB ---
MONGODB_PORT=27017
MONGODB_ROOT_USERNAME=zenandops
MONGODB_ROOT_PASSWORD=zenandops

# --- Kafka ---
KAFKA_PORT=9092

# --- Dashboard Service ---
DASHBOARD_SERVICE_PORT=8082

# --- CMDB Service ---
CMDB_SERVICE_PORT=8083
CMDB_DB_NAME=zenandops-cmdb
CMDB_IMPACT_ANALYSIS_MAX_DEPTH=10

# --- Gateway Service ---
GATEWAY_SERVICE_PORT=8080
GATEWAY_RATE_LIMIT_MAX_REQUESTS=100
GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60

# --- Admin API Service ---
ADMIN_API_SERVICE_PORT=8084

# --- Frontend ---
FRONTEND_PORT=3000

# --- Keycloak ---
KEYCLOAK_PORT=8180
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=zenandops
KEYCLOAK_FRONTEND_CLIENT_ID=zenandops-frontend
KEYCLOAK_BACKEND_CLIENT_ID=zenandops-backend
KEYCLOAK_BACKEND_CLIENT_SECRET=zenandops-backend-secret
KEYCLOAK_URL=http://localhost:8180

# --- Keycloak Frontend (Vite build-time) ---
VITE_KEYCLOAK_URL=http://localhost:8180
VITE_KEYCLOAK_REALM=zenandops
VITE_KEYCLOAK_CLIENT_ID=zenandops-frontend

# --- Observability ---
# Grafana exposed host port
GRAFANA_PORT=3001
# Fluent Bit HTTP monitoring endpoint port
FLUENT_BIT_MONITOR_PORT=2020
# Loki HTTP port for log aggregation
LOKI_PORT=3100
# Mimir HTTP port for metrics storage
MIMIR_PORT=9009
# Tempo HTTP query port for distributed tracing
TEMPO_PORT=3200
# Prometheus HTTP port (scrapes all metric targets, remote-writes to Mimir)
PROMETHEUS_PORT=9090
# OTLP endpoint used by backend services (points directly to Tempo for traces)
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
# Trace sampling ratio (0.0 = no traces, 1.0 = all traces)
OTEL_TRACES_SAMPLER_ARG=1.0
